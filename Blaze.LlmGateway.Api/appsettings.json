        "Enabled": true,
        "ModelId": "brew",
        "Provider": "CodebrewRouter",
        "OwnedBy": "codebrew",
        "Source": "virtual",
        "Capabilities": ["chat", "tools", "streaming", "auto-route"],
        "ToolSupport": true,
        "VisionSupport": false,
